    "<div style=\"background:#101210;border:1px solid #2b2e26;padding:16px 20px;margin:0 0 16px 0;border-radius:0;\"><span style=\"font-family:'Courier New',ui-monospace,monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#FF5A1F;border:1px solid #FF5A1F;padding:2px 6px;border-radius:0;\">07</span><br><br><div style=\"font-family:Arial,Helvetica,sans-serif;font-weight:700;font-size:20px;color:#fff;letter-spacing:-0.3px;margin-bottom:6px;\">Species Interactions \u2014 Do They Work Together?</div></div>"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from natureos.engines.interactions import SpeciesInteraction, InteractionType\n",
    "\n",
    "interaction = SpeciesInteraction(species_list=top_species)\n",
    "interaction_result = interaction.analyse()\n",
    "\n",
    "print(interaction_result.summary())\n",
    "\n",
    "if interaction_result.conflict_pairs:\n",
    "    print(\"Potential conflicts:\")\n",
    "    for pair in interaction_result.conflict_pairs:\n",
    "        print(f\"  - {pair.summary()} \u2014 {pair.rationale}\")\n",
    "else:\n",
    "    print(\"No significant conflicts detected.\")\n",
    "\n",
    "if interaction_result.facilitation_pairs:\n",
    "    print(\"\\nFacilitation relationships:\")\n",
    "    for pair in interaction_result.facilitation_pairs:\n",
    "        print(f\"  - {pair.summary()} \u2014 {pair.rationale}\")"
   ]
