yle=\"font-family:'Courier New',ui-monospace,monospace;padding:14px 18px;border:1px solid #2b2e26;vertical-align:top;background:#0A0B0A;\"><div style=\"font-size:10px;letter-spacing:1px;text-transform:uppercase;color:#83897C;margin-bottom:8px;\">Richness</div><div style=\"font-family:Arial,Helvetica,sans-serif;font-size:22px;font-weight:700;color:#fff;\">5 <span style=\"font-family:'Courier New',ui-monospace,monospace;font-size:12px;color:#83897C;font-weight:400;\">species</span></div><div style=\"font-size:11px;color:#83897C;margin-top:6px;\">Limiting factor for palette</div></td></tr></table></div>"
