    "<div style=\"background:#101210;border:1px solid #2b2e26;padding:16px 20px;margin:0 0 16px 0;border-radius:0;\"><span style=\"font-family:'Courier New',ui-monospace,monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#FF5A1F;border:1px solid #FF5A1F;padding:2px 6px;border-radius:0;\">03</span><br><br><div style=\"font-family:Arial,Helvetica,sans-serif;font-weight:700;font-size:20px;color:#fff;letter-spacing:-0.3px;margin-bottom:6px;\">Habitat Suitability \u2014 Which Species Fit This Site?</div></div>"
   ]
